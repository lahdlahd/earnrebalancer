# Earn API base URL (LI.FI Earn)
# Leave unset to use the built-in /earn-api proxy (avoids CORS in dev and Vercel).
VITE_EARN_BASE_URL=

# LI.FI API base URL
VITE_LIFI_BASE_URL=https://li.quest

# LI.FI API key (optional — only needed for higher rate limits, do NOT expose in frontend)
VITE_LIFI_API_KEY=

# WalletConnect project ID (get one free at https://cloud.walletconnect.com)
# Required for WalletConnect-based wallets (MetaMask mobile, Rainbow, etc.)
VITE_WALLET_CONNECT_PROJECT_ID=
